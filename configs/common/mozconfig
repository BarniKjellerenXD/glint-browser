# Common build config for Glint Browser
# This is loaded first, then the platform-specific mozconfig is loaded on top.
ac_add_options --with-app-name=${binName}
export MOZ_USER_DIR="${name}"
export MOZ_APP_BASENAME=${binName}
export MOZ_DISTRIBUTION_ID=${appId}

# Threading
mk_add_options MOZ_MAKE_FLAGS="-j16"

# Repository info
export MOZ_STUB_INSTALLER=1
export MOZ_INCLUDE_SOURCE_INFO=1
export MOZ_SOURCE_REPO=https://github.com/${vendor}/${name}
export MOZ_SOURCE_CHANGESET=${changeset}
