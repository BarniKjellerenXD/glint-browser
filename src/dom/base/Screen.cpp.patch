// GLINT FARBLING PATCH
#include "mozilla/Preferences.h"
#include "mozilla/glint/GlintFarbling.h"

{
  static bool farblingEnabled = false;
  static bool initialized = false;
  if (!initialized) {
    Preferences::AddBoolVarCache(&farblingEnabled, "privacy.farbling.enabled", false);
    initialized = true;
  }

  if (farblingEnabled) {
    nsAutoCString host;
    nsresult rv = GetCurrentHost(host);
    if (NS_SUCCEEDED(rv) && !host.IsEmpty()) {
      uint32_t hash = mozilla::glint::GlintFarbling::GetHostHash(host);
      
      // Common resolutions pool
      static const struct { uint32_t w, h; } kResolutions[] = {
        {1920, 1080},
        {2560, 1440},
        {3440, 1440},
        {3840, 2160},
      };
      uint32_t idx = hash % (sizeof(kResolutions) / sizeof(kResolutions[0]));
      
      // Override width/height values with the chosen resolution
      return kResolutions[idx].w;  // for GetWidth
      // return kResolutions[idx].h; // for GetHeight
    }
  }
}
// END GLINT FARBLING PATCH
